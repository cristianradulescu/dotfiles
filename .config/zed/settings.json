// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // ─── Fonts ───────────────────────────────────────────────────────────────
  "show_edit_predictions": false,
  "languages": {
    "PHP": {
      "show_edit_predictions": true
    }
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "copilot"
  },
  "ui_font_family": "JetBrainsMonoNL Nerd Font",
  "ui_font_size": 18,
  "ui_font_weight": 400.0,
  "buffer_font_family": "JetBrainsMonoNL Nerd Font",
  "buffer_font_size": 18,
  "buffer_font_weight": 400.0,
  "buffer_line_height": "comfortable",

  // ─── Theme & Icons ───────────────────────────────────────────────────────
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte - No Italics",
    "dark": "Catppuccin Mocha - No Italics"
  },
  "icon_theme": "Catppuccin Mocha",

  // ─── Editor ──────────────────────────────────────────────────────────────
  // tabstop=2 / shiftwidth=2 / expandtab
  "tab_size": 2,
  "hard_tabs": false,
  // nowrap
  "soft_wrap": "none",
  // scrolloff=8 / sidescrolloff=8
  "vertical_scroll_margin": 8,
  "horizontal_scroll_margin": 8,
  // colorcolumn=120
  "wrap_guides": [120],
  // cursorline=true
  "current_line_highlight": "all",
  // list + trailing whitespace indicator
  "show_whitespaces": "boundary",
  // indent guides (indent-blankline equivalent)
  "indent_guides": {
    "enabled": true,
    "coloring": "fixed"
  },
  // inlay hints enabled
  "inlay_hints": {
    "enabled": true
  },
  // signature help on ( — equiv. to on-attach <C-k>
  "auto_signature_help": true,
  // hover delay equiv. to updatetime=250
  "hover_popover_delay": 250,
  // manual formatting only — <leader>cf maps to editor::Format
  "format_on_save": "off",
  // gutter always visible (signcolumn=yes)
  "gutter": {
    "line_numbers": true,
    "folds": true,
    "breakpoints": true,
    "runnables": true
  },
  // selection highlight — equiv. to document highlight on CursorHold
  "selection_highlight": true,
  // splitright / splitbelow
  "pane_split_direction_horizontal": "down",
  "pane_split_direction_vertical": "right",
  // cursor shape in normal mode (block) is handled by vim_mode

  // ─── Vim Mode ────────────────────────────────────────────────────────────
  "vim_mode": true,
  "vim": {
    // relative numbers in normal, absolute in insert
    "toggle_relative_line_numbers": true,
    // clipboard=unnamedplus
    "use_system_clipboard": "always",
    // highlight on yank (200ms)
    "highlight_on_yank_duration": 200,
    // smartcase for f/t motions
    "use_smartcase_find": true
  },

  // ─── Tabs (bufferline equivalent) ────────────────────────────────────────
  "tabs": {
    // LSP diagnostics on buffer tabs (bufferline diagnostics equivalent)
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "history"
  },

  // ─── Git (gitsigns + inline blame equivalent) ────────────────────────────
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600,
      "show_commit_summary": true
    }
  },

  // ─── Terminal ────────────────────────────────────────────────────────────
  "terminal": {
    "font_family": "JetBrainsMonoNL Nerd Font",
    "font_size": 18.0,
    "dock": "left",
    "copy_on_select": false
  },

  // ─── Panels ──────────────────────────────────────────────────────────────
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "button": false
  },
  "project_panel": {
    "starts_open": false,
    // follow current file (neo-tree: follow_current_file = true)
    "auto_fold_dirs": false
  },

  // ─── Title bar ───────────────────────────────────────────────────────────
  "title_bar": {
    "show_user_picture": false,
    "show_branch_icon": false
  },

  // ─── Agent / AI ──────────────────────────────────────────────────────────
  "agent_buffer_font_size": 16.0,
  "agent_ui_font_size": 20.0,
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },

  // ─── Telemetry ───────────────────────────────────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // ─── Autosave ────────────────────────────────────────────────────────────
  "autosave": "on_focus_change",

  // ─── Extensions (auto-install) ───────────────────────────────────────────
  "auto_install_extensions": {
    "php": true,
    "dockerfile": true,
    "docker-compose": true,
    "html": true,
    "sql": true,
    "lua": true,
    "go": true,
    "yaml": true,
    "xml": true,
    "bash": true
  },

  // ─── LSP ─────────────────────────────────────────────────────────────────
  "lsp": {
    // PHP — intelephense: turn off built-in formatting (use external formatter)
    "intelephense": {
      "settings": {
        "intelephense.format.enable": false,
        "intelephense.files.maxSize": 104857600,
        "intelephense.telemetry.enabled": false,
        "intelephense.environment.includePaths": [],
        "intelephense.diagnostics.enable": true
      }
    },
    // Lua — disable telemetry (lua_ls equivalent)
    "lua-language-server": {
      "settings": {
        "Lua": {
          "telemetry": {
            "enable": false
          }
        }
      }
    },
    // YAML — use schemastore schemas
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemaStore": {
            "enable": true,
            "url": "https://www.schemastore.org/api/json/catalog.json"
          },
          "schemas": {},
          "format": {
            "enable": true
          }
        }
      }
    },
    // JSON — use schemastore schemas (jsonls equivalent)
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [],
          "validate": {
            "enable": true
          },
          "format": {
            "enable": true
          }
        }
      }
    }
  }
}
