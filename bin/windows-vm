#!/bin/bash

# Adapted from Omarchy for Ubuntu 24.04
# https://github.com/basecamp/omarchy/blob/master/bin/omarchy-windows-vm
# Supports Sway WM and GNOME

COMPOSE_FILE="$HOME/.config/windows/docker-compose.yml"

# ---------------------------------------------------------------------------
# UI helpers (no external dependencies)
# ---------------------------------------------------------------------------

print_box() {
  local title="$1"; shift
  local width=50
  local border=$(printf '%*s' "$width" '' | tr ' ' '-')
  echo "+${border}+"
  if [ -n "$title" ]; then
    printf "| %-${width}s|\n" "$title"
    echo "+${border}+"
  fi
  for line in "$@"; do
    printf "| %-${width}s|\n" "$line"
  done
  echo "+${border}+"
}

# prompt_choose <header> <default> <option1> <option2> ...
# Sets CHOSEN to the selected value.
prompt_choose() {
  local header="$1"; shift
  local default="$1"; shift
  local options=("$@")

  echo ""
  echo "$header"
  select opt in "${options[@]}"; do
    if [ -n "$opt" ]; then
      CHOSEN="$opt"
      return 0
    fi
    echo "Invalid selection, try again."
  done
}

# prompt_input <header> <default>
# Sets CHOSEN to the entered value (or default if empty).
prompt_input() {
  local header="$1"
  local default="$2"
  echo ""
  read -rp "$header [$default]: " CHOSEN
  CHOSEN="${CHOSEN:-$default}"
}

# prompt_confirm <question>
# Returns 0 for yes, 1 for no.
prompt_confirm() {
  local question="$1"
  echo ""
  read -rp "$question [y/N]: " answer
  case "$answer" in
    [yY][eE][sS]|[yY]) return 0 ;;
    *) return 1 ;;
  esac
}

# ---------------------------------------------------------------------------

check_prerequisites() {
  local DISK_SIZE_GB=${1:-64}
  local REQUIRED_SPACE=$((DISK_SIZE_GB + 10))  # Add 10GB for Windows ISO and overhead

  # Check for KVM support
  if [ ! -e /dev/kvm ]; then
    print_box "ERROR: KVM virtualization not available!" \
      "" \
      "Please enable virtualization in BIOS or run:" \
      "  sudo modprobe kvm-intel  # for Intel CPUs" \
      "  sudo modprobe kvm-amd    # for AMD CPUs"
    exit 1
  fi

  # Check disk space
  AVAILABLE_SPACE=$(df "$HOME" | awk 'NR==2 {print int($4/1024/1024)}')
  if [ "$AVAILABLE_SPACE" -lt "$REQUIRED_SPACE" ]; then
    echo "Insufficient disk space!"
    echo "   Available: ${AVAILABLE_SPACE}GB"
    echo "   Required: ${REQUIRED_SPACE}GB (${DISK_SIZE_GB}GB disk + 10GB for Windows image)"
    exit 1
  fi
}

install_windows() {
  # Set up trap to handle Ctrl+C
  trap "echo ''; echo 'Installation cancelled by user'; exit 1" INT

  check_prerequisites

  sudo apt install -y freerdp3-wayland freerdp3-x11 netcat-openbsd

  mkdir -p "$HOME/.windows"
  mkdir -p "$HOME/.config/windows"

  # Get system resources
  TOTAL_RAM=$(free -h | awk 'NR==2 {print $2}')
  TOTAL_RAM_GB=$(awk 'NR==1 {printf "%d", $2/1024/1024}' /proc/meminfo)
  TOTAL_CORES=$(nproc)

  echo ""
  echo "System Resources Detected:"
  echo "  Total RAM: $TOTAL_RAM"
  echo "  Total CPU Cores: $TOTAL_CORES"
  echo ""

  # Select RAM
  RAM_OPTIONS=()
  for size in 2 4 8 16; do
    if [ "$size" -le "$TOTAL_RAM_GB" ]; then
      RAM_OPTIONS+=("${size}G")
    fi
  done

  prompt_choose "How much RAM would you like to allocate to Windows VM?" "4G" "${RAM_OPTIONS[@]}"
  SELECTED_RAM="$CHOSEN"

  # Select CPU cores
  prompt_input "How many CPU cores would you like to allocate to Windows VM? (1-$TOTAL_CORES)" "2"
  SELECTED_CORES="$CHOSEN"

  if ! [[ "$SELECTED_CORES" =~ ^[0-9]+$ ]] || [ "$SELECTED_CORES" -lt 1 ] || [ "$SELECTED_CORES" -gt "$TOTAL_CORES" ]; then
    echo "Invalid input. Using default: 2 cores"
    SELECTED_CORES=2
  fi

  # Select disk size
  AVAILABLE_SPACE=$(df "$HOME" | awk 'NR==2 {print int($4/1024/1024)}')
  MAX_DISK_GB=$((AVAILABLE_SPACE - 10))  # Leave 10GB for Windows image

  if [ "$MAX_DISK_GB" -lt 32 ]; then
    echo "Insufficient disk space for Windows VM!"
    echo "   Available: ${AVAILABLE_SPACE}GB"
    echo "   Minimum required: 42GB (32GB disk + 10GB for Windows image)"
    exit 1
  fi

  DISK_OPTIONS=()
  for size in 32 64; do
    if [ "$size" -le "$MAX_DISK_GB" ]; then
      DISK_OPTIONS+=("${size}G")
    fi
  done

  prompt_choose "How much disk space would you like to give Windows VM?" "32G" "${DISK_OPTIONS[@]}"
  SELECTED_DISK="$CHOSEN"

  # Extract just the number for prerequisite check
  DISK_SIZE_NUM=$(echo "$SELECTED_DISK" | sed 's/G//')

  # Re-check prerequisites with selected disk size
  check_prerequisites "$DISK_SIZE_NUM"

  # Prompt for username and password
  prompt_input "Enter Windows username" "docker"
  USERNAME="$CHOSEN"

  echo ""
  read -rsp "Enter Windows password [admin]: " PASSWORD
  echo ""
  if [ -z "$PASSWORD" ]; then
    PASSWORD="admin"
    PASSWORD_DISPLAY="(default)"
  else
    PASSWORD_DISPLAY="(user-defined)"
  fi

  # Display configuration summary
  print_box "Windows VM Configuration" \
    "" \
    "RAM:       $SELECTED_RAM" \
    "CPU:       $SELECTED_CORES cores" \
    "Disk:      $SELECTED_DISK" \
    "Username:  $USERNAME" \
    "Password:  $PASSWORD_DISPLAY"

  if ! prompt_confirm "Proceed with this configuration?"; then
    echo "Installation cancelled by user"
    exit 1
  fi

  mkdir -p "$HOME/Windows"

  # Create docker-compose.yml in user config directory
  cat << EOF > "$COMPOSE_FILE"
services:
  windows:
    image: dockurr/windows
    container_name: windows
    environment:
      VERSION: "11"
      RAM_SIZE: "$SELECTED_RAM"
      CPU_CORES: "$SELECTED_CORES"
      DISK_SIZE: "$SELECTED_DISK"
      USERNAME: "$USERNAME"
      PASSWORD: "$PASSWORD"
    devices:
      - /dev/kvm
      - /dev/net/tun
    cap_add:
      - NET_ADMIN
    ports:
      - 8006:8006
      - 3389:3389/tcp
      - 3389:3389/udp
    volumes:
      - $HOME/.windows:/storage
      - $HOME/Windows:/shared
    restart: always
    stop_grace_period: 2m
EOF

  echo ""
  echo "Starting Windows VM installation..."
  echo "This will download a Windows 11 image (may take 10-15 minutes)."
  echo ""
  echo "Monitor installation progress at: http://127.0.0.1:8006"
  echo ""

  # Start docker-compose with user's config
  echo "Starting Windows VM with docker-compose..."
  if ! docker compose -f "$COMPOSE_FILE" up -d 2>&1; then
    echo "Failed to start Windows VM!"
    echo "   Common issues:"
    echo "   - Docker daemon not running: sudo systemctl start docker"
    echo "   - Port already in use: check if another VM is running"
    echo "   - Permission issues: make sure you're in the docker group"
    exit 1
  fi

  echo ""
  echo "Windows VM is starting up!"
  echo ""
  echo "Opening browser to monitor installation..."

  # Open browser to monitor installation
  sleep 3
  xdg-open "http://127.0.0.1:8006"

  echo ""
  echo "Installation is running in the background."
  echo "You can monitor progress at: http://127.0.0.1:8006"
  echo ""
  echo "Once finished, launch the VM with: windows-vm launch"
  echo ""
  echo "To stop the VM: windows-vm stop"
  echo "To change resources: ~/.config/windows/docker-compose.yml"
  echo ""
}

remove_windows() {
  echo "Removing Windows VM..."

  docker compose -f "$COMPOSE_FILE" down 2>/dev/null || true

  docker rmi dockurr/windows 2>/dev/null || echo "Image already removed or not found"

  rm -rf "$HOME/.config/windows"
  rm -rf "$HOME/.windows"

  echo ""
  echo "Windows VM removal completed!"
}

launch_windows() {
  KEEP_ALIVE=false
  if [ "$1" = "--keep-alive" ] || [ "$1" = "-k" ]; then
    KEEP_ALIVE=true
  fi

  # Check if config exists
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Windows VM not configured. Please run: windows-vm install"
    exit 1
  fi

  # Check if container is already running
  CONTAINER_STATUS=$(docker inspect --format='{{.State.Status}}' windows 2>/dev/null)

  if [ "$CONTAINER_STATUS" != "running" ]; then
    echo "Starting Windows VM..."

    # Send desktop notification
    notify-send "Starting Windows VM" "This can take 15-30 seconds" -t 15000

    if ! docker compose -f "$COMPOSE_FILE" up -d 2>&1; then
      echo "Failed to start Windows VM!"
      echo "   Try checking: windows-vm status"
      echo "   View logs: docker logs windows"
      notify-send -u critical "Windows VM" "Failed to start Windows VM"
      exit 1
    fi

    # Wait for RDP to be ready
    echo "Waiting for Windows VM to be ready..."
    WAIT_COUNT=0
    while ! nc -z 127.0.0.1 3389 2>/dev/null; do
      sleep 2
      WAIT_COUNT=$((WAIT_COUNT + 1))
      if [ "$WAIT_COUNT" -gt 60 ]; then  # 2 minutes timeout
        echo "Timeout waiting for RDP!"
        echo "   The VM might still be installing Windows."
        echo "   Check progress at: http://127.0.0.1:8006"
        exit 1
      fi
    done

    # Give it a moment more to fully initialize
    sleep 5
  fi

  # Extract credentials from compose file
  WIN_USER=$(grep "USERNAME:" "$COMPOSE_FILE" | sed 's/.*USERNAME: "\(.*\)"/\1/')
  WIN_PASS=$(grep "PASSWORD:" "$COMPOSE_FILE" | sed 's/.*PASSWORD: "\(.*\)"/\1/')

  # Use defaults if not found
  [ -z "$WIN_USER" ] && WIN_USER="docker"
  [ -z "$WIN_PASS" ] && WIN_PASS="admin"

  # Build the connection info
  if [ "$KEEP_ALIVE" = true ]; then
    LIFECYCLE="VM will keep running after RDP closes. To stop: windows-vm stop"
  else
    LIFECYCLE="VM will auto-stop when RDP closes"
  fi

  print_box "Connecting to Windows VM" "" "$LIFECYCLE"

  # Detect display scale (supports Sway and GNOME)
  detect_scale() {
    if command -v swaymsg &>/dev/null; then
      SWAY_SCALE=$(swaymsg -t get_outputs | jq -r '.[] | select(.focused == true) | .scale')
      echo "$SWAY_SCALE" | awk '{print int($1 * 100)}'
    elif command -v gsettings &>/dev/null; then
      FACTOR=$(gsettings get org.gnome.desktop.interface scaling-factor 2>/dev/null | tr -d "uint32 ")
      echo $(( ${FACTOR:-1} * 100 ))
    else
      echo 100
    fi
  }
  SCALE_PERCENT=$(detect_scale)

  RDP_SCALE=""
  if [ "$SCALE_PERCENT" -ge 170 ]; then
    RDP_SCALE="/scale:180"
  elif [ "$SCALE_PERCENT" -ge 130 ]; then
    RDP_SCALE="/scale:140"
  fi
  # If scale is less than 130%, don't set any scale (use default 100)

  # Connect with RDP in fullscreen (auto-detects resolution)
  xfreerdp3 /u:"$WIN_USER" /p:"$WIN_PASS" /v:127.0.0.1:3389 -grab-keyboard /sound /microphone /cert:ignore /title:"Windows VM" /dynamic-resolution /gfx:AVC444 /floatbar:sticky:off,default:visible,show:fullscreen $RDP_SCALE

  # After RDP closes, stop the container unless --keep-alive was specified
  if [ "$KEEP_ALIVE" = false ]; then
    echo ""
    echo "RDP session closed. Stopping Windows VM..."
    docker compose -f "$COMPOSE_FILE" down
    echo "Windows VM stopped."
  else
    echo ""
    echo "RDP session closed. Windows VM is still running."
    echo "To stop it: windows-vm stop"
  fi
}

stop_windows() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Windows VM not configured."
    exit 1
  fi

  echo "Stopping Windows VM..."
  docker compose -f "$COMPOSE_FILE" down
  echo "Windows VM stopped."
}

status_windows() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Windows VM not configured."
    echo "To set up: windows-vm install"
    exit 1
  fi

  CONTAINER_STATUS=$(docker inspect --format='{{.State.Status}}' windows 2>/dev/null)

  if [ -z "$CONTAINER_STATUS" ]; then
    echo "Windows VM container not found."
    echo "To start: windows-vm launch"
  elif [ "$CONTAINER_STATUS" = "running" ]; then
    print_box "Windows VM Status: RUNNING" \
      "" \
      "Web interface: http://127.0.0.1:8006" \
      "RDP available: port 3389" \
      "" \
      "To connect: windows-vm launch" \
      "To stop:    windows-vm stop"
  else
    echo "Windows VM is stopped (status: $CONTAINER_STATUS)"
    echo "To start: windows-vm launch"
  fi
}

show_usage() {
  echo "Usage: windows-vm [command] [options]"
  echo ""
  echo "Commands:"
  echo "  install              Install and configure Windows VM"
  echo "  remove               Remove Windows VM and optionally its data"
  echo "  launch [options]     Start Windows VM (if needed) and connect via RDP"
  echo "                       Options:"
  echo "                         --keep-alive, -k   Keep VM running after RDP closes"
  echo "  stop                 Stop the running Windows VM"
  echo "  status               Show current VM status"
  echo "  help                 Show this help message"
  echo ""
  echo "Examples:"
  echo "  windows-vm install           # Set up Windows VM for first time"
  echo "  windows-vm launch            # Connect to VM (auto-stop on exit)"
  echo "  windows-vm launch -k         # Connect to VM (keep running)"
  echo "  windows-vm stop              # Shut down the VM"
}

# Main command dispatcher
case "$1" in
  install)
    install_windows
    ;;
  remove)
    remove_windows
    ;;
  launch|start)
    launch_windows "$2"
    ;;
  stop|down)
    stop_windows
    ;;
  status)
    status_windows
    ;;
  help|--help|-h|"")
    show_usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    echo "" >&2
    show_usage >&2
    exit 1
    ;;
esac
