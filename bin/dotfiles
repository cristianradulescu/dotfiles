#!/usr/bin/env bash

DOTFILES_DIR="$HOME/dotfiles"

show_help() {
  cat << EOF
Dotfiles Management Tool

Usage: dotfiles [command] [options]

Commands:
  install [package]   Install specific package or run full installation
  update [package]    Update specific package or all updatable packages
  list                List all available packages
  help                Show this help message

Examples:
  dotfiles install lazygit    # Install/reinstall lazygit
  dotfiles update lazygit     # Update lazygit to latest version
  dotfiles update             # Update all updatable packages
  dotfiles list               # Show all available packages
EOF
}

list_packages() {
  echo "Available packages:"
  echo ""
  echo "CLI Tools:"
  for script in "$DOTFILES_DIR"/install/cli/*.sh; do
    [ -f "$script" ] && echo "  - $(basename "$script" .sh)"
  done
  echo ""
  echo "GUI Tools:"
  for script in "$DOTFILES_DIR"/install/gui/*.sh; do
    [ -f "$script" ] && echo "  - $(basename "$script" .sh)"
  done
  echo ""
  echo "Optional:"
  for script in "$DOTFILES_DIR"/install/optional/*.sh; do
    [ -f "$script" ] && echo "  - $(basename "$script" .sh)"
  done
}

_find_script() {
  local package="$1"
  if [ -f "$DOTFILES_DIR/install/cli/$package.sh" ]; then
    echo "$DOTFILES_DIR/install/cli/$package.sh"
  elif [ -f "$DOTFILES_DIR/install/gui/$package.sh" ]; then
    echo "$DOTFILES_DIR/install/gui/$package.sh"
  elif [ -f "$DOTFILES_DIR/install/optional/$package.sh" ]; then
    echo "$DOTFILES_DIR/install/optional/$package.sh"
  fi
}

install_package() {
  local package="$1"
  local script
  script="$(_find_script "$package")"

  if [ -z "$script" ]; then
    echo "Error: Package '$package' not found"
    echo "Run 'dotfiles list' to see available packages"
    exit 1
  fi

  echo "Installing $package..."
  source "$DOTFILES_DIR/install/lib.sh"
  source "$script" install
}

update_package() {
  local package="$1"
  local script
  script="$(_find_script "$package")"

  if [ -z "$script" ]; then
    echo "Error: Package '$package' not found"
    echo "Run 'dotfiles list' to see available packages"
    exit 1
  fi

  echo "Checking updates for $package..."
  source "$DOTFILES_DIR/install/lib.sh"
  source "$script" update
}

update_all() {
  echo "Checking updates for all packages..."
  echo ""

  local checked=0

  source "$DOTFILES_DIR/install/lib.sh"

  for script in "$DOTFILES_DIR"/install/cli/*.sh \
                "$DOTFILES_DIR"/install/gui/*.sh \
                "$DOTFILES_DIR"/install/optional/*.sh; do
    [ -f "$script" ] || continue

    local name
    name="$(basename "$script" .sh)"
    ((checked++))

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Checking: $name"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    source "$script" update
    echo ""
  done

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "Update check complete! Checked: $checked packages"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# Main command dispatcher
case "${1:-help}" in
  install)
    if [ -z "$2" ]; then
      echo "Error: Please specify a package to install"
      echo "Run 'dotfiles list' to see available packages"
      exit 1
    fi
    install_package "$2"
    ;;
  update)
    if [ -z "$2" ]; then
      update_all
    else
      update_package "$2"
    fi
    ;;
  list)
    list_packages
    ;;
  help|--help|-h)
    show_help
    ;;
  *)
    echo "Error: Unknown command '$1'"
    echo ""
    show_help
    exit 1
    ;;
esac
