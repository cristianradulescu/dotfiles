#!/usr/bin/env bash

# Fix Bluetooth issues on MediaTek MT7925 (Lenovo IdeaPad Pro 5)
#
# Issues addressed:
# 1. USB autosuspend during GNOME login causes btusb to disconnect
# 2. After suspend/resume, the device needs USB reset to rebind
#
# Permanent fix: Install systemd units (see --install option)

set -e

# Find the Bluetooth USB device
find_bt_device() {
    for dev in /sys/bus/usb/devices/[0-9]-*; do
        if [[ -f "$dev/idVendor" && -f "$dev/idProduct" ]]; then
            vendor=$(cat "$dev/idVendor" 2>/dev/null)
            product=$(cat "$dev/idProduct" 2>/dev/null)
            if [[ "$vendor" == "0489" && "$product" == "e111" ]]; then
                echo "$dev"
                return 0
            fi
        fi
    done
    return 1
}

# Reset USB device by unbind/bind cycle
reset_usb_device() {
    local dev_path="$1"
    local dev_name=$(basename "$dev_path")
    
    echo "Resetting USB device $dev_name..."
    
    # Unbind from current driver
    if [[ -L "$dev_path/driver" ]]; then
        echo "$dev_name" | sudo tee /sys/bus/usb/drivers/usb/unbind > /dev/null 2>&1 || true
    fi
    
    sleep 1
    
    # Rebind
    echo "$dev_name" | sudo tee /sys/bus/usb/drivers/usb/bind > /dev/null 2>&1 || true
    
    sleep 2
}

# Check if interfaces are bound to btusb
check_btusb_bound() {
    local dev_path="$1"
    [[ -L "$dev_path:1.0/driver" ]] && \
    [[ "$(readlink "$dev_path:1.0/driver" 2>/dev/null)" == *btusb* ]]
}

install_systemd_units() {
    echo "Installing systemd units for automatic Bluetooth fix..."
    
    # Create udev rule - trigger on add AND change, also set autosuspend delay
    sudo tee /etc/udev/rules.d/91-mt7925-bluetooth.rules > /dev/null << 'EOF'
# Disable USB autosuspend for MediaTek MT7925 Bluetooth
ACTION=="add|change", SUBSYSTEM=="usb", ATTR{idVendor}=="0489", ATTR{idProduct}=="e111", ATTR{power/control}="on", ATTR{power/autosuspend_delay_ms}="-1"
EOF

    # Create systemd service that runs at boot AND after resume
    sudo tee /etc/systemd/system/btusb-fix.service > /dev/null << 'EOF'
[Unit]
Description=Fix MediaTek MT7925 Bluetooth
After=bluetooth.service
Wants=bluetooth.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash -c '\
  sleep 3; \
  for dev in /sys/bus/usb/devices/[0-9]-*; do \
    if [ -f "$dev/idVendor" ] && [ "$(cat $dev/idVendor 2>/dev/null)" = "0489" ] && [ "$(cat $dev/idProduct 2>/dev/null)" = "e111" ]; then \
      echo on > "$dev/power/control" 2>/dev/null || true; \
      echo -1 > "$dev/power/autosuspend_delay_ms" 2>/dev/null || true; \
      if [ ! -L "$dev:1.0/driver" ]; then \
        devname=$(basename $dev); \
        echo "$devname" > /sys/bus/usb/drivers/usb/unbind 2>/dev/null || true; \
        sleep 1; \
        echo "$devname" > /sys/bus/usb/drivers/usb/bind 2>/dev/null || true; \
        sleep 2; \
        systemctl restart bluetooth; \
      fi; \
      break; \
    fi; \
  done'

[Install]
WantedBy=multi-user.target
EOF

    # Create systemd service for resume
    sudo tee /etc/systemd/system/btusb-fix-resume.service > /dev/null << 'EOF'
[Unit]
Description=Fix Bluetooth after resume
After=suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c '\
  sleep 2; \
  for dev in /sys/bus/usb/devices/[0-9]-*; do \
    if [ -f "$dev/idVendor" ] && [ "$(cat $dev/idVendor 2>/dev/null)" = "0489" ] && [ "$(cat $dev/idProduct 2>/dev/null)" = "e111" ]; then \
      devname=$(basename $dev); \
      echo "$devname" > /sys/bus/usb/drivers/usb/unbind 2>/dev/null || true; \
      sleep 1; \
      echo "$devname" > /sys/bus/usb/drivers/usb/bind 2>/dev/null || true; \
      sleep 2; \
      echo on > "$dev/power/control" 2>/dev/null || true; \
      echo -1 > "$dev/power/autosuspend_delay_ms" 2>/dev/null || true; \
      systemctl restart bluetooth; \
      break; \
    fi; \
  done'

[Install]
WantedBy=suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target
EOF

    # Reload and enable
    sudo udevadm control --reload-rules
    sudo udevadm trigger --subsystem-match=usb --attr-match=idVendor=0489 --attr-match=idProduct=e111
    sudo systemctl daemon-reload
    sudo systemctl enable btusb-fix.service
    sudo systemctl enable btusb-fix-resume.service
    sudo systemctl start btusb-fix.service
    
    echo "Done! Bluetooth should now work after boot, login, and resume."
    echo ""
    echo "Installed:"
    echo "  - /etc/udev/rules.d/91-mt7925-bluetooth.rules"
    echo "  - /etc/systemd/system/btusb-fix.service (boot)"
    echo "  - /etc/systemd/system/btusb-fix-resume.service (resume)"
}

uninstall_systemd_units() {
    echo "Removing systemd units..."
    sudo systemctl disable btusb-fix.service 2>/dev/null || true
    sudo systemctl disable btusb-fix-resume.service 2>/dev/null || true
    sudo rm -f /etc/systemd/system/btusb-fix.service
    sudo rm -f /etc/systemd/system/btusb-fix-resume.service
    sudo rm -f /etc/udev/rules.d/91-mt7925-bluetooth.rules
    sudo udevadm control --reload-rules
    sudo systemctl daemon-reload
    echo "Done!"
}

# Handle --install / --uninstall flags
if [[ "$1" == "--install" ]]; then
    install_systemd_units
    exit 0
elif [[ "$1" == "--uninstall" ]]; then
    uninstall_systemd_units
    exit 0
fi

echo "Fixing Bluetooth for MediaTek MT7925..."

BT_USB_PATH=$(find_bt_device)

if [[ -z "$BT_USB_PATH" ]]; then
    echo "ERROR: Cannot find MediaTek Bluetooth USB device (0489:e111)"
    echo "The device may need a full power cycle (shutdown, not reboot)"
    exit 1
fi

echo "Found Bluetooth device at: $BT_USB_PATH"

# Disable USB autosuspend
echo "Disabling USB autosuspend..."
echo 'on' | sudo tee "$BT_USB_PATH/power/control" > /dev/null

# Check if btusb module is loaded
if ! lsmod | grep -q btusb; then
    echo "Loading btusb module..."
    sudo modprobe btusb
fi

# Check if driver is bound to interfaces
if ! check_btusb_bound "$BT_USB_PATH"; then
    echo "btusb not bound to device, resetting USB..."
    reset_usb_device "$BT_USB_PATH"
    
    # Wait for btusb to bind
    for i in {1..5}; do
        if check_btusb_bound "$BT_USB_PATH"; then
            break
        fi
        sleep 1
    done
fi

# Restart bluetooth service
echo "Restarting Bluetooth service..."
sudo systemctl restart bluetooth

# Wait for controller
echo "Waiting for Bluetooth controller..."
for i in {1..10}; do
    if bluetoothctl show 2>/dev/null | grep -q "Controller"; then
        break
    fi
    sleep 1
done

# Status check
echo ""
echo "=== Status ==="

if bluetoothctl show 2>/dev/null | grep -q "Controller"; then
    echo "Bluetooth controller is available."
    bluetoothctl show | grep -E "Name|Address|Powered" | head -3
    
    # Power on if needed
    if ! bluetoothctl show 2>/dev/null | grep -q "Powered: yes"; then
        echo "Powering on Bluetooth..."
        sleep 2  # Wait for controller to be ready
        for i in {1..3}; do
            if bluetoothctl power on 2>/dev/null; then
                break
            fi
            sleep 1
        done
    fi
    
    echo ""
    echo "Run 'btusb-fix --install' to make this permanent (fixes login + resume)"
else
    echo "ERROR: No Bluetooth controller found."
    echo ""
    echo "Try a full shutdown (not reboot) and start again."
    echo "Check logs: journalctl -b -k | grep -iE 'btusb|hci|bluetooth'"
    exit 1
fi
